{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Doom Master",
  "version": "0.1.0",
  "identifier": "com.doommaster.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DOOM MASTER",
        "url": "index.html?desktop-build=0.1.0",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "fullscreen": false,
        "transparent": false,
        "shadow": false,
        "visible": false,
        "backgroundColor": "#1a1b26"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}